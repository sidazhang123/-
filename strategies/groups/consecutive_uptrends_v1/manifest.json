{
  "id": "consecutive_uptrends_v1",
  "name": "K线连续小阳 v1",
  "description": "多周期连续小阳检测：在日线/周线/60分钟线中识别连续 m 根小阳线（可选急跌回撤段），各周期独立检测，结果取并集（OR）。",
  "module": "strategies.groups.consecutive_uptrends_v1",
  "engine": "specialized",
  "execution": {
    "requires_time_window": false,
    "supports_intra_task_parallel": false,
    "cache_scope": "none",
    "required_timeframes": ["w", "d", "60"],
    "specialized_entry": "strategies.groups.consecutive_uptrends_v1.engine:run_consecutive_uptrends_v1_specialized"
  },
  "usage": ["screening", "backtest"],
  "default_params": {
    "weekly": {
      "scope_params": ["scan_bars"],
      "enabled": false,
      "scan_bars": 20,
      "streak_len": 5,
      "bar_gain_max": 2.0,
      "selloff_enabled": false,
      "selloff_start_pct": 50.0,
      "selloff_return_pct": 70.0,
      "selloff_bars": 3
    },
    "daily": {
      "scope_params": ["scan_bars"],
      "enabled": true,
      "scan_bars": 20,
      "streak_len": 5,
      "bar_gain_max": 2.0,
      "selloff_enabled": false,
      "selloff_start_pct": 50.0,
      "selloff_return_pct": 70.0,
      "selloff_bars": 3
    },
    "min60": {
      "scope_params": ["scan_bars"],
      "enabled": false,
      "scan_bars": 20,
      "streak_len": 5,
      "bar_gain_max": 2.0,
      "selloff_enabled": false,
      "selloff_start_pct": 50.0,
      "selloff_return_pct": 70.0,
      "selloff_bars": 3
    },
    "universe_filters": {
      "concepts": {
        "enabled": false,
        "concept_terms": [],
        "reason_terms": []
      }
    },
    "filter_st": {
      "enabled": true
    },
    "execution": {
      "fallback_to_backtrader": false
    }
  },
  "param_help": {
    "_overview": [
      "该策略在周线、日线、60分钟线三个周期中独立检测连续小阳形态。",
      "必选条件：在最近 n 根 K 线中存在 m 根连续阳线（close > open），每根涨幅不超过 p%。",
      "可选条件（急跌段）：连阳结束后的一定偏移范围内出现连续 z 根急跌线，跌幅达到连阳总涨幅的 y%。",
      "多周期之间为并集关系（OR）：任一启用周期检测到连续小阳即产生信号。"
    ],
    "weekly": {
      "_render": "inline_template",
      "_label": "周线",
      "_tf_key": "w",
      "_templates": [
        {
          "text": "在最新的 {scan_bars} 根K线中查找连续小阳",
          "required": true,
          "help": "仅在筛选模式中生效"
        },
        {
          "text": "至少 {streak_len} 根连续阳线",
          "required": true
        },
        {
          "text": "每根阳线涨幅不超过 {bar_gain_max}%",
          "required": true
        },
        {
          "text": "启用急跌检查",
          "required": false,
          "toggle": "selloff_enabled"
        },
        {
          "text": "急跌起始偏移上限：连阳长度的 {selloff_start_pct}%",
          "required": false,
          "help": "连阳结束后最多间隔 floor(偏移% × 连阳根数) 根K线开始急跌",
          "follow_toggle": "selloff_enabled"
        },
        {
          "text": "急跌连续 {selloff_bars} 根K线",
          "required": false,
          "follow_toggle": "selloff_enabled"
        },
        {
          "text": "急跌回撤不超过连阳涨幅的 {selloff_return_pct}%",
          "required": false,
          "help": "回撤 = (连阳最高收盘价 − 急跌最低收盘价) / 连阳总涨幅",
          "follow_toggle": "selloff_enabled"
        }
      ]
    },
    "daily": {
      "_render": "inline_template",
      "_label": "日线",
      "_tf_key": "d",
      "_templates": [
        {
          "text": "在最新的 {scan_bars} 根K线中查找连续小阳",
          "required": true,
          "help": "仅在筛选模式中生效"
        },
        {
          "text": "至少 {streak_len} 根连续阳线",
          "required": true
        },
        {
          "text": "每根阳线涨幅不超过 {bar_gain_max}%",
          "required": true
        },
        {
          "text": "启用急跌检查",
          "required": false,
          "toggle": "selloff_enabled"
        },
        {
          "text": "急跌起始偏移上限：连阳长度的 {selloff_start_pct}%",
          "required": false,
          "help": "连阳结束后最多间隔 floor(偏移% × 连阳根数) 根K线开始急跌",
          "follow_toggle": "selloff_enabled"
        },
        {
          "text": "急跌连续 {selloff_bars} 根K线",
          "required": false,
          "follow_toggle": "selloff_enabled"
        },
        {
          "text": "急跌回撤不超过连阳涨幅的 {selloff_return_pct}%",
          "required": false,
          "help": "回撤 = (连阳最高收盘价 − 急跌最低收盘价) / 连阳总涨幅",
          "follow_toggle": "selloff_enabled"
        }
      ]
    },
    "min60": {
      "_render": "inline_template",
      "_label": "60分钟线",
      "_tf_key": "60",
      "_templates": [
        {
          "text": "在最新的 {scan_bars} 根K线中查找连续小阳",
          "required": true,
          "help": "仅在筛选模式中生效"
        },
        {
          "text": "至少 {streak_len} 根连续阳线",
          "required": true
        },
        {
          "text": "每根阳线涨幅不超过 {bar_gain_max}%",
          "required": true
        },
        {
          "text": "启用急跌检查",
          "required": false,
          "toggle": "selloff_enabled"
        },
        {
          "text": "急跌起始偏移上限：连阳长度的 {selloff_start_pct}%",
          "required": false,
          "help": "连阳结束后最多间隔 floor(偏移% × 连阳根数) 根K线开始急跌",
          "follow_toggle": "selloff_enabled"
        },
        {
          "text": "急跌连续 {selloff_bars} 根K线",
          "required": false,
          "follow_toggle": "selloff_enabled"
        },
        {
          "text": "急跌回撤不超过连阳涨幅的 {selloff_return_pct}%",
          "required": false,
          "help": "回撤 = (连阳最高收盘价 − 急跌最低收盘价) / 连阳总涨幅",
          "follow_toggle": "selloff_enabled"
        }
      ]
    },
    "universe_filters": {
      "concepts": {
        "enabled": "是否启用概念预筛选。",
        "concept_terms": "概念名称关键字列表，语义为 AND（全部命中才保留）。",
        "reason_terms": "选股理由关键字列表，语义为 OR（任一命中即保留）。"
      }
    },
    "filter_st": {
      "enabled": "是否在筛选时排除名称包含 ST（不分大小写）的股票。默认开启。"
    },
    "execution": {
      "fallback_to_backtrader": "specialized 失败后是否降级到 backtrader，默认 false。"
    }
  }
}
