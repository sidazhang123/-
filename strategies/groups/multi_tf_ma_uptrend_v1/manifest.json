{
  "id": "multi_tf_ma_uptrend_v1",
  "name": "多周期均线向上 v1",
  "description": "多周期均线方向筛选：检查各周期（周线/日线/60分钟/15分钟）MA 均线斜率百分比是否稳定落在指定区间内，可选连续窗口、收盘偏离和收敛震荡条件。例如：筛选「4根周线的MA5斜率在10%-20% + 最近15根日线的MA20斜率在15%-35% + 最新日线距MA10偏离<5% + 最后5根15min线振幅<3%」。",
  "module": "strategies.groups.multi_tf_ma_uptrend_v1",
  "engine": "specialized",
  "execution": {
    "requires_time_window": false,
    "supports_intra_task_parallel": false,
    "cache_scope": "none",
    "required_timeframes": ["w", "d", "60", "15"],
    "specialized_entry": "strategies.groups.multi_tf_ma_uptrend_v1.engine:run_multi_tf_ma_uptrend_v1_specialized"
  },
  "usage": ["screening", "backtest"],
  "default_params": {
    "weekly": {
      "scope_params": ["n"],
      "enabled": false,
      "n": 20,
      "ma_period": 10,
      "slope_gap": 4,
      "slope_min": 10.0,
      "slope_max": 20.0,
      "continuous_check": false,
      "close_deviation_enabled": false,
      "close_deviation_ma_period": 10,
      "close_deviation_pct": 5.0,
      "consolidation_enabled": false,
      "consolidation_bars": 3,
      "consolidation_max_amp_pct": 3.0
    },
    "daily": {
      "scope_params": ["n"],
      "enabled": true,
      "n": 20,
      "ma_period": 10,
      "slope_gap": 4,
      "slope_min": 10.0,
      "slope_max": 20.0,
      "continuous_check": false,
      "close_deviation_enabled": false,
      "close_deviation_ma_period": 10,
      "close_deviation_pct": 5.0,
      "consolidation_enabled": false,
      "consolidation_bars": 3,
      "consolidation_max_amp_pct": 3.0
    },
    "min60": {
      "scope_params": ["n"],
      "enabled": false,
      "n": 20,
      "ma_period": 10,
      "slope_gap": 4,
      "slope_min": 10.0,
      "slope_max": 20.0,
      "continuous_check": false,
      "close_deviation_enabled": false,
      "close_deviation_ma_period": 10,
      "close_deviation_pct": 5.0,
      "consolidation_enabled": false,
      "consolidation_bars": 3,
      "consolidation_max_amp_pct": 3.0
    },
    "min15": {
      "scope_params": ["n"],
      "enabled": false,
      "n": 20,
      "ma_period": 10,
      "slope_gap": 4,
      "slope_min": 10.0,
      "slope_max": 20.0,
      "continuous_check": false,
      "close_deviation_enabled": false,
      "close_deviation_ma_period": 10,
      "close_deviation_pct": 5.0,
      "consolidation_enabled": false,
      "consolidation_bars": 3,
      "consolidation_max_amp_pct": 3.0
    },
    "universe_filters": {
      "concepts": {
        "enabled": false,
        "concept_terms": [],
        "reason_terms": []
      }
    },
    "filter_st": {
      "enabled": true
    },
    "execution": {
      "fallback_to_backtrader": false
    }
  },
  "param_help": {
    "_overview": [
      "该策略支持周线、日线、60分钟线、15分钟线四个周期，每个周期可独立启用或关闭。",
      "均线斜率公式为百分比：100 × (MA当前 − MA过去) / (MA过去 × 间隔根数)，单位为 %/根。",
      "例如 slope_min=10, slope_max=20 表示斜率需在 10%~20% 之间。",
      "「连续筛选」开启后，若 n ≥ 2×slope_gap，会对所有不重叠窗口做斜率检查。",
      "收盘偏离：检查最后一根线收盘价是否在指定 MA 均线的正负百分比范围内。",
      "收敛震荡：检查最后若干根线的最高-最低区间振幅是否小于阈值百分比。"
    ],
    "weekly": {
      "_render": "inline_template",
      "_label": "周线",
      "_tf_key": "w",
      "_templates": [
        {
          "text": "在最新的 {n} 根线中",
          "required": true,
          "help": "仅在筛选模式中生效"
        },
        {
          "text": "存在MA {ma_period} 均线",
          "required": true
        },
        {
          "text": "间隔 {slope_gap} 根线的两端MA值涨幅范围是 [{slope_min}%, {slope_max}%]",
          "required": true
        },
        {
          "text": "连续筛选",
          "toggle": "continuous_check",
          "help": "若 n ≥ 2×间隔根数，需同时对 [t-m, t-2m]、[t-2m, t-3m]…等所有不重叠窗口满足斜率条件"
        },
        {
          "text": "最后1根线的收盘价距离MA {close_deviation_ma_period} 均线偏离幅度 {close_deviation_pct} %",
          "toggle": "close_deviation_enabled"
        },
        {
          "text": "最后 {consolidation_bars} 根线在振幅< {consolidation_max_amp_pct} %的区间内收敛震荡",
          "toggle": "consolidation_enabled"
        }
      ]
    },
