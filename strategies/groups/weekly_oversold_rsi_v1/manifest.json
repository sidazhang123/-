{
  "id": "weekly_oversold_rsi_v1",
  "name": "周线超跌 v1",
  "description": "周线 RSI 超跌筛选：最近一根周线的 RSI(m) 低于绝对阈值且不高于该股票历史最低 RSI(m) 的 y%。",
  "module": "strategies.groups.weekly_oversold_rsi_v1",
  "engine": "specialized",
  "execution": {
    "requires_time_window": false,
    "supports_intra_task_parallel": false,
    "cache_scope": "none",
    "required_timeframes": ["w"],
    "specialized_entry": "strategies.groups.weekly_oversold_rsi_v1.engine:run_weekly_oversold_rsi_v1_specialized"
  },
  "usage": ["screening", "backtest"],
  "default_params": {
    "weekly": {
      "rsi_period": 14,
      "rsi_threshold": 24,
      "historical_ratio_pct": 120.0
    },
    "universe_filters": {
      "concepts": {
        "enabled": false,
        "concept_terms": [],
        "reason_terms": []
      }
    },
    "filter_st": {
      "enabled": true
    },
    "execution": {
      "fallback_to_backtrader": false
    }
  },
  "param_help": {
    "_overview": [
      "该策略仅使用周线数据，筛选 RSI 处于历史性超跌区域的股票。",
      "命中条件：最近一根周线的 RSI(m) 同时满足两个约束——低于绝对阈值 x，且不高于该股票全部历史周线中最低 RSI(m) 的 y%。",
      "历史最低 RSI 按每只股票在数据库中所有可用周线数据计算，不限定固定起始日期。"
    ],
    "weekly": {
      "_render": "inline_template",
      "_label": "周线",
      "_tf_key": "w",
      "_templates": [
        {
          "text": "RSI 计算周期 {rsi_period}",
          "required": true,
          "help": "Wilder RSI 平滑周期"
        },
        {
          "text": "最近一根周线 RSI 低于 {rsi_threshold}",
          "required": true
        },
        {
          "text": "且不高于历史最低 RSI 的 {historical_ratio_pct}%",
          "required": true,
          "help": "历史最低 RSI = 该股票全部周线数据中 RSI(m) 的最小值"
        }
      ]
    },
    "universe_filters": {
      "concepts": {
        "enabled": "是否启用概念预筛选。",
        "concept_terms": "概念名称关键字列表，语义为 AND（全部命中才保留）。",
        "reason_terms": "选股理由关键字列表，语义为 OR（任一命中即保留）。"
      }
    },
    "filter_st": {
      "enabled": "是否在筛选时排除名称包含 ST（不分大小写）的股票。默认开启。"
    },
    "execution": {
      "fallback_to_backtrader": "specialized 失败后是否降级到 backtrader，默认 false。"
    }
  }
}
